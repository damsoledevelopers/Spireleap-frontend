## Frontend environment variables (Next.js)
#
# Copy this file to `.env.local` and fill in values.
# Restart `npm run dev` after changes.
#
# Base URL of the Express backend (Spireleap-Backend). Must resolve to `.../api` exactly once.
# Examples: http://localhost:5000/api  or  https://your-host.com/api
# Avoid .../api/ (trailing slash) or .../api/api — those used to produce 404s on every route.
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Google Maps   
# Enable these APIs in Google Cloud:
# - Maps JavaScript API (used by `components/GoogleMapPicker.js`)
# - Places API (used for address search)
# - Maps Embed API (used by property details iframe)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

